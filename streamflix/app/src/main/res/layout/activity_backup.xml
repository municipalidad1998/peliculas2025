<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Backup a Telegram"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Token del Bot:"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/tokenEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: 123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZ"
        android:inputType="text"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ID del Chat:"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/chatIdEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: -1001234567890"
        android:inputType="number"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/backupButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Iniciar Backup"
        android:textAllCaps="false"/>

</LinearLayout>